# Render backend
RATIS_MASTER_KEY=replace-with-a-long-random-secret

# Neon Free pooled connection string (copy the -pooler URL from Neon)
DATABASE_URL=postgresql://user:password@ep-example-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Cloudflare R2 private bucket credentials
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=ratis-photos

# Used only by `npm run r2:configure-cors`
R2_ALLOWED_ORIGINS=https://transmission-webapp.vercel.app,http://127.0.0.1:8000,http://localhost:8000
